<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="pageRoot" prefHeight="720" prefWidth="1100" style="-fx-background-color: #99a3b9;" styleClass="owner-root tenant-root" stylesheets="@style.css" userData="tenant-house-details.fxml" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.TenantController">
    <left>
        <VBox maxWidth="250.0" prefHeight="720.0" prefWidth="163.0" spacing="18" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="16" right="16" top="24" />
            </padding>

            <VBox spacing="4" styleClass="brand-block">
                <Label styleClass="brand-title" text="To-•Let" />
                <Label styleClass="brand-subtitle" text="Tenant Dashboard" />
            </VBox>

            <VBox spacing="6">
                <Button fx:id="navDashboardButton" onAction="#onOpenDashboard" prefHeight="35.0" prefWidth="204.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Dashboard" />
                <Button fx:id="navSearchButton" onAction="#onOpenSearch" prefHeight="35.0" prefWidth="189.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37; -fx-border-color: #D4AF37; -fx-border-radius: 10;" styleClass="nav-button" text="Properties" />
                <Button fx:id="navWishlistButton" onAction="#onOpenWishlist" prefHeight="35.0" prefWidth="212.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Wishlist" />
                <Button fx:id="navReviewButton" onAction="#onOpenReview" prefHeight="35.0" prefWidth="320.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Review" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox maxWidth="278.0" prefWidth="278.0" spacing="10" style="-fx-background-color: #1F2933;" styleClass="profile-card">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="profileNameLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-name" text="Tenant" />
                </HBox>
                <Label fx:id="profileVerificationLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Status - Active" />
                <Label fx:id="profileRoleLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Role - Tenant" />
                <Label fx:id="profileEmailLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Email: -" />
                <Label fx:id="profilePhoneLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Phone: -" />
                <Button onAction="#onLogout" prefHeight="30.0" prefWidth="217.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37; -fx-border-color: #D4AF37;" styleClass="ghost-button" text="Logout" />
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #99a3b9;" styleClass="content-scroll">
            <VBox prefHeight="1200.0" prefWidth="760.0" spacing="18" style="-fx-background-color: #99a3b9;" styleClass="content-root">
                <HBox alignment="TOP_RIGHT">
                    <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" styleClass="theme-switch">
                        <graphic>
                            <Region styleClass="switch-knob" />
                        </graphic>
                    </ToggleButton>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #1F2933;" styleClass="top-bar" spacing="10">
                    <Button onAction="#onOpenSearch" styleClass="ghost-button" text="← Back to Properties" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-text-fill: #D4AF37; -fx-font-size: 18px; -fx-font-weight: 700;" text="Property Details" />
                </HBox>

                <VBox spacing="10" styleClass="panel">
                    <StackPane style="-fx-background-color: #1F2933; -fx-background-radius: 16; -fx-padding: 12;">
                        <ImageView fx:id="detailsImageView" fitHeight="340" fitWidth="760" pickOnBounds="true" preserveRatio="false" smooth="true" />
                        <HBox alignment="CENTER" spacing="640.0">
                            <Button onAction="#onPreviousDetailImage" style="-fx-background-color: rgba(17,24,39,0.75); -fx-text-fill: #D4AF37; -fx-font-size: 16px; -fx-background-radius: 999;" text="❮" />
                            <Button onAction="#onNextDetailImage" style="-fx-background-color: rgba(17,24,39,0.75); -fx-text-fill: #D4AF37; -fx-font-size: 16px; -fx-background-radius: 999;" text="❯" />
                        </HBox>
                    </StackPane>
                    <HBox alignment="CENTER_RIGHT">
                        <Label fx:id="detailsImageCounterLabel" style="-fx-text-fill: #00fbff; -fx-font-weight: 700;" text="1 / 1" />
                    </HBox>
                </VBox>

                <VBox spacing="12" styleClass="panel">
                    <Label fx:id="detailsTitleLabel" style="-fx-text-fill: #D4AF37; -fx-font-size: 24px; -fx-font-weight: 800;" text="Property Title" wrapText="true" />
                    <Label fx:id="detailsLocationLabel" style="-fx-text-fill: #D4AF37; -fx-font-size: 15px;" text="Location" />
                    <Label fx:id="detailsRentLabel" style="-fx-text-fill: #f95748; -fx-font-size: 20px; -fx-font-weight: 700;" text="BDT 0 / month" />
                    <Button onAction="#onBookNowFromDetails" style="-fx-background-color: #0f766e; -fx-text-fill: #ffffff; -fx-font-weight: 700; -fx-background-radius: 10; -fx-padding: 10 20 10 20;" text="Book Now" />
                </VBox>

                <GridPane hgap="14" vgap="10" styleClass="panel">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                    </columnConstraints>

                    <Label style="-fx-text-fill: #D4AF37; -fx-font-weight: 700;" text="Owner" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Label fx:id="detailsOwnerLabel" style="-fx-text-fill: #ffffff;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label style="-fx-text-fill: #D4AF37; -fx-font-weight: 700;" text="Availability" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label fx:id="detailsAvailabilityLabel" style="-fx-text-fill: #ffffff;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label style="-fx-text-fill: #D4AF37; -fx-font-weight: 700;" text="Contact" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label fx:id="detailsContactLabel" style="-fx-text-fill: #ffffff;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label style="-fx-text-fill: #D4AF37; -fx-font-weight: 700;" text="Type" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <Label fx:id="detailsTypeLabel" style="-fx-text-fill: #ffffff;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label style="-fx-text-fill: #D4AF37; -fx-font-weight: 700;" text="Bedrooms" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <Label fx:id="detailsBedroomsLabel" style="-fx-text-fill: #ffffff;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                    <Label style="-fx-text-fill: #D4AF37; -fx-font-weight: 700;" text="Bathrooms" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <Label fx:id="detailsBathroomsLabel" style="-fx-text-fill: #ffffff;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <Label style="-fx-text-fill: #D4AF37; -fx-font-weight: 700;" text="Area" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <Label fx:id="detailsAreaLabel" style="-fx-text-fill: #ffffff;" text="0 sqft" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                </GridPane>

                <VBox spacing="8" styleClass="panel">
                    <Label style="-fx-text-fill: #D4AF37; -fx-font-size: 16px; -fx-font-weight: 700;" text="Summary" />
                    <Label fx:id="detailsShortDetailLabel" style="-fx-text-fill: #ffffff;" text="-" wrapText="true" />
                </VBox>

                <VBox spacing="8" styleClass="panel">
                    <Label style="-fx-text-fill: #D4AF37; -fx-font-size: 16px; -fx-font-weight: 700;" text="Description" />
                    <Label fx:id="detailsDescriptionLabel" style="-fx-text-fill: #ffffff;" text="-" wrapText="true" />
                </VBox>

                <VBox spacing="8" styleClass="panel">
                    <Label style="-fx-text-fill: #D4AF37; -fx-font-size: 16px; -fx-font-weight: 700;" text="Amenities" />
                    <Label fx:id="detailsAmenitiesLabel" style="-fx-text-fill: #ffffff;" text="-" wrapText="true" />
                </VBox>

                <VBox spacing="8" styleClass="panel">
                    <Label style="-fx-text-fill: #D4AF37; -fx-font-size: 16px; -fx-font-weight: 700;" text="Tags" />
                    <FlowPane fx:id="detailsTagsContainer" hgap="8" prefWrapLength="700" vgap="8" />
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
