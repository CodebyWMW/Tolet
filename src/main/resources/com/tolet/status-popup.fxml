<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="250.0" prefWidth="420.0" style="-fx-background-color: linear-gradient(to bottom right, #6d83c7, #9cc6ff, #d4af37); -fx-background-radius: 20; -fx-padding: 0; -fx-effect: dropshadow(gaussian, rgba(20, 39, 87, 0.22), 26, 0.22, 0, 10);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="TOP_LEFT" prefHeight="246.0" prefWidth="416.0" spacing="14" style="-fx-background-color: linear-gradient(to bottom right, #99a3b9, #99a3bf); -fx-background-radius: 18;">
        <StackPane.margin>
            <Insets bottom="2" left="2" right="2" top="2" />
        </StackPane.margin>
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="popupIconLabel" style="-fx-background-color: #e9f2ff; -fx-text-fill: #1e4bd8; -fx-font-size: 22; -fx-font-weight: 800; -fx-alignment: center; -fx-min-width: 40; -fx-min-height: 40; -fx-max-width: 40; -fx-max-height: 40; -fx-background-radius: 999;" text="!" />
            <VBox spacing="4">
                <Label fx:id="popupTitleLabel" style="-fx-text-fill: #1c2f57; -fx-font-size: 20; -fx-font-weight: 800;" text="Done" />
                <Label style="-fx-text-fill: #5671a8; -fx-font-size: 12;" text="To-•let" />
            </VBox>
        </HBox>

        <Label fx:id="popupMessageLabel" style="-fx-text-fill: #2f4574; -fx-font-size: 14; -fx-line-spacing: 2;" text="Status message" wrapText="true" />

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button fx:id="popupCancelButton" style="-fx-background-color: rgba(40, 75, 145, 0.15); -fx-border-color: #8ea8df; -fx-text-fill: #22417d; -fx-font-size: 13; -fx-font-weight: 800; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10 18 10 18; -fx-cursor: hand;" text="Cancel" />
            <Button fx:id="popupOkButton" style="-fx-background-color: linear-gradient(to right, #0f74ff, #1da3ff); -fx-text-fill: #ffffff; -fx-font-size: 13; -fx-font-weight: 800; -fx-background-radius: 10; -fx-padding: 10 24 10 24; -fx-cursor: hand;" text="OK" />
        </HBox>
    </VBox>
</StackPane>
