<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="pageRoot" prefHeight="600" prefWidth="900" style="-fx-background-color: #99a3b9;" styleClass="owner-root tenant-root" stylesheets="@style.css" userData="tenant-view.fxml" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.TenantController">
    <left>
        <VBox maxWidth="250.0" prefHeight="600.0" prefWidth="163.0" spacing="18" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="16" right="16" top="24" />
            </padding>

            <VBox spacing="4" styleClass="brand-block">
                <Label styleClass="brand-title" text="To-•Let" />
                <Label styleClass="brand-subtitle" text="Tenant Dashboard" />
            </VBox>

            <VBox spacing="6">
                <Button fx:id="navDashboardButton" onAction="#onOpenDashboard" prefHeight="35.0" prefWidth="204.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37; -fx-border-color: #D4AF37; -fx-border-radius: 10;" styleClass="nav-button" text="Dashboard" />
                <Button fx:id="navSearchButton" onAction="#onOpenSearch" prefHeight="35.0" prefWidth="189.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Properties" />
                <Button fx:id="navWishlistButton" onAction="#onOpenWishlist" prefHeight="35.0" prefWidth="212.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Wishlist" />
                <Button fx:id="navReviewButton" onAction="#onOpenReview" prefHeight="35.0" prefWidth="320.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Review" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox maxWidth="278.0" prefWidth="278.0" spacing="10" style="-fx-background-color: #1F2933;" styleClass="profile-card">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="profileNameLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-name" text="Tenant" />
                </HBox>
                <Label fx:id="profileVerificationLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Status - Active" />
                <Label fx:id="profileRoleLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Role - Tenant" />
                <Label fx:id="profileEmailLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Email: -" />
                <Label fx:id="profilePhoneLabel" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Phone: -" />
                <Button onAction="#onLogout" prefHeight="30.0" prefWidth="217.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37; -fx-border-color: #D4AF37;" styleClass="ghost-button" text="Logout" />
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #99a3b9;" styleClass="content-scroll">
            <VBox prefHeight="1080.0" prefWidth="691.0" spacing="22" style="-fx-background-color: #99a3b9;" styleClass="content-root">
                <HBox alignment="TOP_RIGHT">
                    <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" styleClass="theme-switch">
                        <graphic>
                            <Region styleClass="switch-knob" />
                        </graphic>
                    </ToggleButton>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #1F2933;" styleClass="top-bar">
                    <VBox spacing="4">
                        <Label style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="page-title" text="Dashboard" />
                        <Label fx:id="welcomeLabel" style="-fx-text-fill: #D4AF37;" styleClass="page-subtitle" text="Welcome back" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox spacing="16" styleClass="kpi-row">
                    <VBox spacing="6" style="-fx-background-color: #1F2933;" styleClass="kpi-card">
                        <Label style="-fx-text-fill: #D4AF37;" styleClass="kpi-title" text="Saved Homes" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="savedHomesLabel" style="-fx-text-fill: #D4AF37;" styleClass="kpi-value" text="0" />
                            <Region styleClass="kpi-icon kpi-icon-blue" />
                        </HBox>
                    </VBox>
                    <VBox spacing="6" style="-fx-background-color: #1F2933;" styleClass="kpi-card">
                        <Label style="-fx-text-fill: #D4AF37;" styleClass="kpi-title" text="Booked Requests" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="bookedRequestsLabel" style="-fx-text-fill: #D4AF37;" styleClass="kpi-value" text="0" />
                            <Region styleClass="kpi-icon kpi-icon-orange" />
                        </HBox>
                    </VBox>
                    <VBox spacing="6" style="-fx-background-color: #1F2933;" styleClass="kpi-card">
                        <Label style="-fx-text-fill: #D4AF37;" styleClass="kpi-title" text="Listed Houses" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="listedHousesLabel" style="-fx-text-fill: #D4AF37;" styleClass="kpi-value" text="0" />
                            <Region styleClass="kpi-icon kpi-icon-blue" />
                        </HBox>
                    </VBox>
                </HBox>

                <HBox fx:id="bookingStatusCard" alignment="CENTER_LEFT" managed="false" spacing="12" styleClass="status-card" visible="false">
                    <VBox spacing="2">
                        <Label fx:id="bookingStatusTitleLabel" style="-fx-font-weight: bold; -fx-text-fill: #854d0e;" text="Booking Pending" />
                        <Label fx:id="bookingStatusMessageLabel" style="-fx-text-fill: #a16207;" text="Your latest request is being reviewed." />
                    </VBox>
                </HBox>

                <VBox fx:id="currentRentedHouseContainer" maxHeight="1000.0" prefHeight="260.0" prefWidth="643.0" spacing="12" styleClass="panel" managed="false" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="panel-title" text="Your Current Rented House" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>
                    <Separator />
                    <FlowPane fx:id="currentRentedHouseGrid" hgap="24" prefWrapLength="1000" vgap="24" />
                </VBox>

                <VBox maxHeight="1000.0" prefHeight="260.0" prefWidth="643.0" spacing="12" styleClass="panel">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="panel-title" text="Available Properties" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onOpenSearch" styleClass="ghost-button" text="See More" />
                    </HBox>
                    <Separator />
                    <FlowPane fx:id="propertiesGrid" hgap="24" prefWrapLength="1000" vgap="24" />
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

