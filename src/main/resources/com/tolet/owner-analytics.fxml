<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="600" prefWidth="900" style="-fx-background-color: #99a3b4;" styleClass="owner-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.OwnerController">
    <left>
        <VBox maxWidth="250.0" prefHeight="600.0" prefWidth="163.0" spacing="18" styleClass="sidebar">
            <VBox spacing="4" styleClass="brand-block">
                <Label prefHeight="23.0" prefWidth="158.0" styleClass="brand-title" text="To-•Let" />
                <Label prefHeight="14.0" prefWidth="183.0" styleClass="brand-subtitle" text="Owner Dashboard" />
            </VBox>

            <VBox spacing="6">
                <Button onAction="#onOpenDashboard" prefHeight="35.0" prefWidth="204.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Dashboard" />
                <Button onAction="#onOpenAcceptedTenants" prefHeight="35.0" prefWidth="189.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Tenants" />
                <Button onAction="#onOpenProperties" prefHeight="35.0" prefWidth="212.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Properties" />
                <Button onAction="#onOpenRequests" prefHeight="35.0" prefWidth="207.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="nav-button" text="Requests" />
                <Button onAction="#onOpenAnalytics" prefHeight="35.0" prefWidth="320.0" style="-fx-background-color: #233142; -fx-text-fill: #D4AF37; -fx-border-color: #D4AF37; -fx-border-radius: 10;" styleClass="nav-button" text="Analytics" />
                <Button onAction="#onOpenListHouse" prefHeight="42.0" prefWidth="320.0" styleClass="list-house-cta" text="+ List New House" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox maxWidth="278.0" prefHeight="300.0" prefWidth="278.0" spacing="6" style="-fx-background-color: #1F2933;" styleClass="profile-card">
                <StackPane alignment="CENTER">
                    <Circle fill="#2b3b48" radius="79.0" stroke="#D4AF37" strokeWidth="1.5" />
                    <ImageView fx:id="profileAvatarImage" fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="false" />
                </StackPane>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="profileNameLabel" prefHeight="27.0" prefWidth="197.0" style="-fx-text-fill: #D4AF37;" styleClass="profile-name" text="Owner" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#onOpenProfile" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37; -fx-border-color: #D4AF37; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 2 8;" text="&#9998;" />
                </HBox>                <Label fx:id="profileVerificationLabel" prefHeight="20.0" prefWidth="215.0" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Status - Unverified" />
                <Label fx:id="profileRoleLabel" prefHeight="20.0" prefWidth="215.0" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Role - Owner" />
                <Label fx:id="profileEmailLabel" prefHeight="20.0" prefWidth="189.0" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Email: -" />
                <Label fx:id="profilePhoneLabel" prefHeight="20.0" prefWidth="241.0" style="-fx-text-fill: #D4AF37;" styleClass="profile-role" text="Phone: -" />
                <Button onAction="#onLogout" prefHeight="30.0" prefWidth="217.0" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37; -fx-border-color: #D4AF37;" styleClass="ghost-button" text="Logout" />
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #99a3b4;" styleClass="content-scroll">
            <VBox fx:id="analyticsPageRoot" prefHeight="1080.0" prefWidth="691.0" spacing="22" style="-fx-background-color: #99a3b4;" styleClass="content-root">
                <HBox alignment="TOP_RIGHT">
                    <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" styleClass="theme-switch">
                        <graphic>
                            <Region styleClass="switch-knob" />
                        </graphic>
                    </ToggleButton>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #1F2933;" styleClass="top-bar">
                    <VBox spacing="4">
                        <Label style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="page-title" text="Analytics" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="dateLabel" style="-fx-background-color: #1F2933; -fx-text-fill: #D4AF37;" styleClass="date-pill" text="" />
                </HBox>

                <HBox spacing="14">
                    <VBox spacing="4" style="-fx-background-color: #1F2933;" styleClass="kpi-card"><Label style="-fx-text-fill: #D4AF37;" text="Properties" /><Label fx:id="analyticsTotalPropertiesLabel" style="-fx-text-fill: #D4AF37; -fx-font-size: 20; -fx-font-weight: 800;" text="0" /></VBox>
                    <VBox spacing="4" style="-fx-background-color: #1F2933;" styleClass="kpi-card"><Label style="-fx-text-fill: #D4AF37;" text="Total Requests" /><Label fx:id="analyticsTotalRequestsLabel" style="-fx-text-fill: #D4AF37; -fx-font-size: 20; -fx-font-weight: 800;" text="0" /></VBox>
                    <VBox spacing="4" style="-fx-background-color: #1F2933;" styleClass="kpi-card"><Label style="-fx-text-fill: #D4AF37;" text="Approved" /><Label fx:id="analyticsApprovedRequestsLabel" style="-fx-text-fill: #21b66f; -fx-font-size: 20; -fx-font-weight: 800;" text="0" /></VBox>
                    <VBox spacing="4" style="-fx-background-color: #1F2933;" styleClass="kpi-card"><Label style="-fx-text-fill: #D4AF37;" text="Pending" /><Label fx:id="analyticsPendingRequestsLabel" style="-fx-text-fill: #d9b542; -fx-font-size: 20; -fx-font-weight: 800;" text="0" /></VBox>
                    <VBox spacing="4" style="-fx-background-color: #1F2933;" styleClass="kpi-card"><Label style="-fx-text-fill: #D4AF37;" text="Denied" /><Label fx:id="analyticsDeniedRequestsLabel" style="-fx-text-fill: #dc5b5b; -fx-font-size: 20; -fx-font-weight: 800;" text="0" /></VBox>
                </HBox>

                <VBox spacing="12" styleClass="panel">
                    <Label styleClass="panel-title" text="Performance" />
                    <HBox alignment="CENTER_LEFT" spacing="18">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #D4AF37;" text="Approval Rate" />
                            <ProgressBar fx:id="analyticsApprovalBar" prefWidth="260" progress="0" />
                            <Label fx:id="analyticsApprovalRateLabel" style="-fx-text-fill: #D4AF37;" text="0%" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #D4AF37;" text="Occupancy Indicator" />
                            <ProgressBar fx:id="analyticsOccupancyBar" prefWidth="260" progress="0" />
                            <Label fx:id="analyticsOccupancyRateLabel" style="-fx-text-fill: #D4AF37;" text="0%" />
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="10" styleClass="panel">
                    <Label styleClass="panel-title" text="Requests (Last 6 Months)" />
                    <LineChart fx:id="analyticsRequestsTrendChart" animated="false" createSymbols="true" legendVisible="false" minHeight="220.0" prefHeight="220.0" title="">
                        <xAxis>
                            <CategoryAxis />
                        </xAxis>
                        <yAxis>
                            <NumberAxis lowerBound="0.0" tickUnit="1.0" />
                        </yAxis>
                    </LineChart>
                </VBox>

                <HBox spacing="14">
                    <VBox spacing="8" styleClass="panel" HBox.hgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Revenue Intelligence" />
                        <Label style="-fx-text-fill: #D4AF37;" text="Average Rent" />
                        <Label fx:id="analyticsAvgRentLabel" style="-fx-text-fill: #D4AF37; -fx-font-size: 22; -fx-font-weight: 800;" text="৳0" />
                        <Label style="-fx-text-fill: #D4AF37;" text="Estimated Monthly Revenue" />
                        <Label fx:id="analyticsEstimatedRevenueLabel" style="-fx-text-fill: #21b66f; -fx-font-size: 22; -fx-font-weight: 800;" text="Ã Â§Â³0" />
                    </VBox>
                    <VBox spacing="8" styleClass="panel" HBox.hgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Trend Signals" />
                        <Label style="-fx-text-fill: #D4AF37;" text="Top Demand Property" />
                        <Label fx:id="analyticsTopPropertyLabel" style="-fx-text-fill: #D4AF37;" text="-" wrapText="true" />
                        <Label style="-fx-text-fill: #D4AF37;" text="Latest Activity" />
                        <Label fx:id="analyticsLatestActivityLabel" style="-fx-text-fill: #D4AF37;" text="-" wrapText="true" />
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>




