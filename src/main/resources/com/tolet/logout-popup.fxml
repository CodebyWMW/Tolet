<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="330.0" prefWidth="460.0" style="-fx-background-color: linear-gradient(to bottom right, #6d83c7, #9cc6ff, #d4af37); -fx-background-radius: 20; -fx-padding: 0; -fx-effect: dropshadow(gaussian, rgba(20, 39, 87, 0.24), 26, 0.22, 0, 10);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="TOP_CENTER" prefHeight="326.0" prefWidth="456.0" spacing="14" style="-fx-background-color: linear-gradient(to bottom right, #99a3b9, #99a3bf); -fx-background-radius: 18;">
        <StackPane.margin>
            <Insets bottom="2" left="2" right="2" top="2" />
        </StackPane.margin>
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <Label style="-fx-background-color: #e9f2ff; -fx-text-fill: #1e4bd8; -fx-font-size: 36; -fx-font-weight: 800; -fx-alignment: center; -fx-min-width: 74; -fx-min-height: 74; -fx-max-width: 74; -fx-max-height: 74; -fx-background-radius: 999;" text="!" />

        <Label style="-fx-text-fill: #1c2f57; -fx-font-size: 20; -fx-font-weight: 800;" text="Loging out already" />

        <Label alignment="CENTER" maxWidth="Infinity" minHeight="48.0" prefHeight="48.0" style="-fx-text-fill: #2f4574; -fx-font-size: 14; -fx-line-spacing: 2;" text="Goodbye! Don't worry,&#10;the server is used to being ghosted by now." textAlignment="CENTER" wrapText="true" />

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button fx:id="cancelButton" style="-fx-background-color: rgba(40, 75, 145, 0.15); -fx-border-color: #8ea8df; -fx-text-fill: #22417d; -fx-font-size: 13; -fx-font-weight: 800; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10 18 10 18; -fx-cursor: hand;" text="Let me doom-scroll more" />
            <Button fx:id="yesButton" style="-fx-background-color: linear-gradient(to right, #0f74ff, #1da3ff); -fx-text-fill: #ffffff; -fx-font-size: 13; -fx-font-weight: 800; -fx-background-radius: 10; -fx-padding: 10 20 10 20; -fx-cursor: hand;" text="Get me the hell outta here" />
        </HBox>
    </VBox>
</StackPane>
