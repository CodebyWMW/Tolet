<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="pageRoot" prefHeight="720" prefWidth="1100" style="-fx-background-color: #262627;" styleClass="owner-root" userData="tenant-house-details.fxml" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.TenantController">
    <stylesheets>
        <URL value="@style.css" />
        <URL value="@dark-style.css" />
        <URL value="@dark-theme.css" />
    </stylesheets>

    <left>
        <VBox maxWidth="250.0" prefHeight="720.0" prefWidth="163.0" spacing="18" style="-fx-background-color: #474743;" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="16" right="16" top="24" />
            </padding>

            <VBox spacing="4" styleClass="brand-block">
                <Label style="-fx-text-fill: #ff7547;" styleClass="brand-title" text="To-•Let" />
                <Label style="-fx-text-fill: #faa387;" styleClass="brand-subtitle" text="Tenant Dashboard" />
            </VBox>

            <VBox spacing="6">
                <Button fx:id="navDashboardButton" onAction="#onOpenDashboard" prefHeight="35.0" prefWidth="189.0" style="-fx-background-color: #262624; -fx-text-fill: #ff7547;" styleClass="nav-button" text="Dashboard" />
                <Button fx:id="navSearchButton" onAction="#onOpenSearch" prefHeight="35.0" prefWidth="189.0" style="-fx-background-color: #262624; -fx-background-radius: 10; -fx-text-fill: #ff7547; -fx-border-color: #ff7547; -fx-border-radius: 10;" styleClass="nav-button" text="Properties" />
                <Button fx:id="navWishlistButton" onAction="#onOpenWishlist" prefHeight="35.0" prefWidth="212.0" style="-fx-background-color: #262624; -fx-text-fill: #ff7547;" styleClass="nav-button" text="Wishlist" />
                <Button fx:id="navReviewButton" onAction="#onOpenReview" prefHeight="35.0" prefWidth="320.0" style="-fx-background-color: #262624; -fx-text-fill: #ff7547;" styleClass="nav-button" text="Review" />
            </VBox>

            <Region style="-fx-background-color: #474743;" VBox.vgrow="ALWAYS" />

            <VBox maxWidth="215.0" prefWidth="215.0" spacing="10" style="-fx-background-color: #262624;" styleClass="profile-card">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="profileNameLabel" style="-fx-text-fill: #ff7547;" styleClass="profile-name" text="Tenant" />
                </HBox>
                <Label fx:id="profileVerificationLabel" style="-fx-text-fill: #faa387;" styleClass="profile-role" text="Status - Active" />
                <Label fx:id="profileRoleLabel" style="-fx-text-fill: #faa387;" styleClass="profile-role" text="Role - Tenant" />
                <Label fx:id="profileEmailLabel" style="-fx-text-fill: #faa387;" styleClass="profile-role" text="Email: -" />
                <Label fx:id="profilePhoneLabel" style="-fx-text-fill: #faa387;" styleClass="profile-role" text="Phone: -" />
                <Button onAction="#onLogout" prefHeight="34.0" prefWidth="264.0" style="-fx-background-color: #474743; -fx-text-fill: #e8fff5; -fx-border-color: #e8fff5;" styleClass="ghost-button" text="Logout" />
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #262624;" styleClass="content-scroll">
            <VBox prefHeight="1200.0" prefWidth="760.0" spacing="18" style="-fx-background-color: #262624;" styleClass="content-root">
                <HBox alignment="TOP_RIGHT">
                    <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" style="-fx-background-color: #99a3b4;" styleClass="theme-switch">
                        <graphic>
                            <Region style="-fx-background-color: #5700d2;" styleClass="switch-knob" />
                        </graphic>
                    </ToggleButton>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #30302e;" styleClass="top-bar" spacing="10">
                    <Button onAction="#onOpenSearch" style="-fx-background-color: #474743; -fx-text-fill: #e8fff5; -fx-border-color: #e8fff5;" styleClass="ghost-button" text="← Back to Properties" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-text-fill: #ff7547; -fx-font-size: 18px; -fx-font-weight: 700;" text="Property Details" />
                </HBox>

                <VBox spacing="10" style="-fx-background-color: #30302e;" styleClass="panel">
                    <StackPane style="-fx-background-color: #1f1f1e; -fx-background-radius: 16; -fx-padding: 12;">
                        <ImageView fx:id="detailsImageView" fitHeight="340" fitWidth="760" pickOnBounds="true" preserveRatio="false" smooth="true" />
                        <HBox alignment="CENTER" spacing="640.0">
                            <Button onAction="#onPreviousDetailImage" style="-fx-background-color: rgba(0,0,0,0.55); -fx-text-fill: #ff7547; -fx-font-size: 16px; -fx-background-radius: 999;" text="❮" />
                            <Button onAction="#onNextDetailImage" style="-fx-background-color: rgba(0,0,0,0.55); -fx-text-fill: #ff7547; -fx-font-size: 16px; -fx-background-radius: 999;" text="❯" />
                        </HBox>
                    </StackPane>
                    <HBox alignment="CENTER_RIGHT">
                        <Label fx:id="detailsImageCounterLabel" style="-fx-text-fill: #faa387; -fx-font-weight: 700;" text="1 / 1" />
                    </HBox>
                </VBox>

                <VBox spacing="12" style="-fx-background-color: #30302e;" styleClass="panel">
                    <Label fx:id="detailsTitleLabel" style="-fx-text-fill: #ff7547; -fx-font-size: 24px; -fx-font-weight: 800;" text="Property Title" wrapText="true" />
                    <Label fx:id="detailsLocationLabel" style="-fx-text-fill: #e8fff5; -fx-font-size: 15px;" text="Location" />
                    <Label fx:id="detailsRentLabel" style="-fx-text-fill: #39ac4d; -fx-font-size: 20px; -fx-font-weight: 700;" text="BDT 0 / month" />
                    <Button onAction="#onBookNowFromDetails" style="-fx-background-color: #0f766e; -fx-text-fill: #ffffff; -fx-font-weight: 700; -fx-background-radius: 10; -fx-padding: 10 20 10 20;" text="Book Now" />
                </VBox>

                <GridPane hgap="14" vgap="10" style="-fx-background-color: #30302e;" styleClass="panel">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                    </columnConstraints>

                    <Label style="-fx-text-fill: #faa387; -fx-font-weight: 700;" text="Owner" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Label fx:id="detailsOwnerLabel" style="-fx-text-fill: #e8fff5;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label style="-fx-text-fill: #faa387; -fx-font-weight: 700;" text="Availability" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label fx:id="detailsAvailabilityLabel" style="-fx-text-fill: #e8fff5;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label style="-fx-text-fill: #faa387; -fx-font-weight: 700;" text="Contact" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label fx:id="detailsContactLabel" style="-fx-text-fill: #e8fff5;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label style="-fx-text-fill: #faa387; -fx-font-weight: 700;" text="Type" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <Label fx:id="detailsTypeLabel" style="-fx-text-fill: #e8fff5;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label style="-fx-text-fill: #faa387; -fx-font-weight: 700;" text="Bedrooms" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <Label fx:id="detailsBedroomsLabel" style="-fx-text-fill: #e8fff5;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                    <Label style="-fx-text-fill: #faa387; -fx-font-weight: 700;" text="Bathrooms" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <Label fx:id="detailsBathroomsLabel" style="-fx-text-fill: #e8fff5;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <Label style="-fx-text-fill: #faa387; -fx-font-weight: 700;" text="Area" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <Label fx:id="detailsAreaLabel" style="-fx-text-fill: #e8fff5;" text="0 sqft" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                </GridPane>

                <VBox spacing="8" style="-fx-background-color: #30302e;" styleClass="panel">
                    <Label style="-fx-text-fill: #ff7547; -fx-font-size: 16px; -fx-font-weight: 700;" text="Summary" />
                    <Label fx:id="detailsShortDetailLabel" style="-fx-text-fill: #e8fff5;" text="-" wrapText="true" />
                </VBox>

                <VBox spacing="8" style="-fx-background-color: #30302e;" styleClass="panel">
                    <Label style="-fx-text-fill: #ff7547; -fx-font-size: 16px; -fx-font-weight: 700;" text="Description" />
                    <Label fx:id="detailsDescriptionLabel" style="-fx-text-fill: #e8fff5;" text="-" wrapText="true" />
                </VBox>

                <VBox spacing="8" style="-fx-background-color: #30302e;" styleClass="panel">
                    <Label style="-fx-text-fill: #ff7547; -fx-font-size: 16px; -fx-font-weight: 700;" text="Amenities" />
                    <Label fx:id="detailsAmenitiesLabel" style="-fx-text-fill: #e8fff5;" text="-" wrapText="true" />
                </VBox>

                <VBox spacing="8" style="-fx-background-color: #30302e;" styleClass="panel">
                    <Label style="-fx-text-fill: #ff7547; -fx-font-size: 16px; -fx-font-weight: 700;" text="Tags" />
                    <FlowPane fx:id="detailsTagsContainer" hgap="8" prefWrapLength="700" vgap="8" />
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
