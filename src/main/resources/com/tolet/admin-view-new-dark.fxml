<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600" prefWidth="900" style="-fx-background-color: linear-gradient(to bottom right, #1f1f1e, #262624 42%, #2f2f2d);" stylesheets="@dark-theme.css,@dark-style.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.AdminController">
    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #2a2a28, #393937); -fx-padding: 18 22 18 22; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.45), 20, 0.24, 0, 7);">
            <Label text="Admin Dashboard" style="-fx-text-fill: #ff8b62; -fx-font-size: 26; -fx-font-weight: 800;">
                <font>
                    <Font name="System Bold" size="24" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="adminNameLabel" text="Admin" style="-fx-text-fill: #faa387; -fx-font-size: 14; -fx-padding: 0 16 0 0;" />
            <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" styleClass="theme-switch">
                <graphic>
                    <Region styleClass="switch-knob" />
                </graphic>
            </ToggleButton>
            <Button text="Logout" onAction="#onLogout" style="-fx-background-color: rgba(255, 117, 71, 0.18); -fx-text-fill: #ffd8cb; -fx-border-color: #ff8b62; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-weight: 700;">
                <HBox.margin>
                    <Insets left="16" />
                </HBox.margin>
            </Button>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: transparent; -fx-tab-min-width: 152; -fx-tab-max-height: 38; -fx-open-tab-animation: grow; -fx-close-tab-animation: grow;">
            <!-- User Management Tab -->
            <Tab text="User Management">
                <VBox spacing="16" style="-fx-padding: 22; -fx-background-color: rgba(56, 56, 54, 0.72); -fx-background-radius: 16;">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="Filter by Role:" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #faa387;" />
                        <ComboBox fx:id="roleFilterCombo" promptText="All Users" style="-fx-background-color: #30302e; -fx-text-fill: #e8fff5; -fx-background-radius: 10; -fx-border-radius: 10;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="userCountLabel" text="Total Users: 0" style="-fx-font-size: 14; -fx-text-fill: #faa387;" />
                    </HBox>

                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #2f2f2d; -fx-control-inner-background: #2f2f2d; -fx-table-cell-border-color: #4c4c49; -fx-text-fill: #e8fff5; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #454543; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.18, 0, 6);">
                        <columns>
                            <TableColumn fx:id="userIdCol" text="User ID" prefWidth="90" />
                            <TableColumn fx:id="userNameCol" text="Name" prefWidth="180" />
                            <TableColumn fx:id="userEmailCol" text="Email" prefWidth="220" />
                            <TableColumn fx:id="userPhoneCol" text="Phone" prefWidth="140" />
                            <TableColumn fx:id="userBirthdateCol" text="Birthdate" prefWidth="120" />
                            <TableColumn fx:id="userRoleCol" text="Role" prefWidth="100" />
                            <TableColumn fx:id="userVerifiedCol" text="Verified" prefWidth="100" />
                            <TableColumn fx:id="userActionsCol" text="Actions" prefWidth="200" />
                            <TableColumn fx:id="userDeleteCol" text="Delete" prefWidth="120" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- House Listings Tab -->
            <Tab text="House Listings">
                <VBox spacing="16" style="-fx-padding: 22; -fx-background-color: rgba(56, 56, 54, 0.72); -fx-background-radius: 16;">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="Filter by Status:" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #faa387;" />
                        <ComboBox fx:id="statusFilterCombo" promptText="All Listings" style="-fx-background-color: #30302e; -fx-text-fill: #e8fff5; -fx-background-radius: 10; -fx-border-radius: 10;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="houseCountLabel" text="Total Houses: 0" style="-fx-font-size: 14; -fx-text-fill: #faa387;" />
                    </HBox>

                    <TableView fx:id="housesTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #2f2f2d; -fx-control-inner-background: #2f2f2d; -fx-table-cell-border-color: #4c4c49; -fx-text-fill: #e8fff5; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #454543; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.18, 0, 6);">
                        <columns>
                            <TableColumn fx:id="houseIdCol" text="ID" prefWidth="60" />
                            <TableColumn fx:id="houseTitleCol" text="Title" prefWidth="220" />
                            <TableColumn fx:id="houseLocationCol" text="Location" prefWidth="210" />
                            <TableColumn fx:id="houseOwnerIdCol" text="Owner ID" prefWidth="100" />
                            <TableColumn fx:id="houseFeaturesCol" text="Features" prefWidth="250" />
                            <TableColumn fx:id="houseStatusCol" text="Status" prefWidth="100" />
                            <TableColumn fx:id="houseActionsCol" text="Actions" prefWidth="250" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tenant Verification Tab -->
            <Tab text="Tenant Verification">
                <VBox spacing="16" style="-fx-padding: 22; -fx-background-color: rgba(56, 56, 54, 0.72); -fx-background-radius: 16;">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="Unverified Tenants" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #ff7547;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="unverifiedCountLabel" text="Unverified: 0" style="-fx-font-size: 14; -fx-text-fill: #ff7547;" />
                    </HBox>

                    <TableView fx:id="tenantsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #2f2f2d; -fx-control-inner-background: #2f2f2d; -fx-table-cell-border-color: #4c4c49; -fx-text-fill: #e8fff5; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #454543; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.18, 0, 6);">
                        <columns>
                            <TableColumn fx:id="tenantIdCol" text="ID" prefWidth="60" />
                            <TableColumn fx:id="tenantNameCol" text="Name" prefWidth="200" />
                            <TableColumn fx:id="tenantEmailCol" text="Email" prefWidth="250" />
                            <TableColumn fx:id="tenantPhoneCol" text="Phone" prefWidth="150" />
                            <TableColumn fx:id="tenantBirthdateCol" text="Birthdate" prefWidth="130" />
                            <TableColumn fx:id="tenantVerifiedCol" text="Status" prefWidth="120" />
                            <TableColumn fx:id="tenantActionsCol" text="Actions" prefWidth="200" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Audit Log Tab -->
            <Tab text="Deleted Users Log">
                <VBox spacing="16" style="-fx-padding: 22; -fx-background-color: rgba(56, 56, 54, 0.72); -fx-background-radius: 16;">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="Deleted Users History" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #ff7547;" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>

                    <TableView fx:id="auditTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #2f2f2d; -fx-control-inner-background: #2f2f2d; -fx-table-cell-border-color: #4c4c49; -fx-text-fill: #e8fff5; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #454543; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.18, 0, 6);">
                        <columns>
                            <TableColumn fx:id="auditUserIdCol" text="User ID" prefWidth="80" />
                            <TableColumn fx:id="auditNameCol" text="Name" prefWidth="160" />
                            <TableColumn fx:id="auditEmailCol" text="Email" prefWidth="200" />
                            <TableColumn fx:id="auditPhoneCol" text="Phone" prefWidth="140" />
                            <TableColumn fx:id="auditRoleCol" text="Role" prefWidth="120" />
                            <TableColumn fx:id="auditDeletedAtCol" text="Deleted At" prefWidth="160" />
                            <TableColumn fx:id="auditDeletedByCol" text="Deleted By" prefWidth="140" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Statistics Tab -->
            <Tab text="Statistics">
                <VBox spacing="24" style="-fx-padding: 28; -fx-background-color: rgba(56, 56, 54, 0.72); -fx-background-radius: 16;" alignment="TOP_CENTER">
                    <Label text="Platform Statistics" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #ff7547;" />

                    <GridPane hgap="18" vgap="18">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="33" />
                            <ColumnConstraints percentWidth="33" />
                            <ColumnConstraints percentWidth="34" />
                        </columnConstraints>

                        <!-- Total Users Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #2d2d2b, #393937); -fx-background-radius: 14; -fx-padding: 24; -fx-alignment: CENTER; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.16, 0, 6);" GridPane.columnIndex="0">
                            <Label text="Total Users" style="-fx-text-fill: #faa387; -fx-font-size: 14;" />
                            <Label fx:id="statsTotalUsersLabel" text="0" style="-fx-text-fill: #e8fff5; -fx-font-size: 36; -fx-font-weight: bold;" />
                        </VBox>

                        <!-- Total Houses Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #2d2d2b, #393937); -fx-background-radius: 14; -fx-padding: 24; -fx-alignment: CENTER; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.16, 0, 6);" GridPane.columnIndex="1">
                            <Label text="Total Houses" style="-fx-text-fill: #faa387; -fx-font-size: 14;" />
                            <Label fx:id="statsTotalHousesLabel" text="0" style="-fx-text-fill: #e8fff5; -fx-font-size: 36; -fx-font-weight: bold;" />
                        </VBox>

                        <!-- Pending Approvals Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #2d2d2b, #393937); -fx-background-radius: 14; -fx-padding: 24; -fx-alignment: CENTER; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.16, 0, 6);" GridPane.columnIndex="2">
                            <Label text="Pending Approvals" style="-fx-text-fill: #faa387; -fx-font-size: 14;" />
                            <Label fx:id="statsPendingLabel" text="0" style="-fx-text-fill: #e8fff5; -fx-font-size: 36; -fx-font-weight: bold;" />
                        </VBox>

                        <!-- Owners Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #2d2d2b, #393937); -fx-background-radius: 14; -fx-padding: 24; -fx-alignment: CENTER; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.16, 0, 6);" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Owners" style="-fx-text-fill: #faa387; -fx-font-size: 14;" />
                            <Label fx:id="statsOwnersLabel" text="0" style="-fx-text-fill: #e8fff5; -fx-font-size: 36; -fx-font-weight: bold;" />
                        </VBox>

                        <!-- Tenants Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #2d2d2b, #393937); -fx-background-radius: 14; -fx-padding: 24; -fx-alignment: CENTER; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.16, 0, 6);" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Tenants" style="-fx-text-fill: #faa387; -fx-font-size: 14;" />
                            <Label fx:id="statsTenantsLabel" text="0" style="-fx-text-fill: #e8fff5; -fx-font-size: 36; -fx-font-weight: bold;" />
                        </VBox>

                        <!-- Unverified Users Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #2d2d2b, #393937); -fx-background-radius: 14; -fx-padding: 24; -fx-alignment: CENTER; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.42), 14, 0.16, 0, 6);" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <Label text="Unverified Users" style="-fx-text-fill: #faa387; -fx-font-size: 14;" />
                            <Label fx:id="statsUnverifiedLabel" text="0" style="-fx-text-fill: #e8fff5; -fx-font-size: 36; -fx-font-weight: bold;" />
                        </VBox>
                    </GridPane>

                    <StackPane>
                        <Button fx:id="refreshStatsButton" text="Refresh Statistics" onAction="#onRefreshStatisticsAnimated" style="-fx-background-color: linear-gradient(to right, #3c3c39, #4a4a46); -fx-text-fill: #ffe3d9; -fx-border-color: #ff8b62; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 12 24; -fx-font-size: 14; -fx-font-weight: 700; -fx-cursor: hand;" />
                        <Rectangle fx:id="refreshFillRect" mouseTransparent="true" width="0" height="40" arcWidth="12" arcHeight="12" fill="#ff7547" opacity="0" StackPane.alignment="CENTER" />
                    </StackPane>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
