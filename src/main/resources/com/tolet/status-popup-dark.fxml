<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="250.0" prefWidth="420.0" style="-fx-background-color: linear-gradient(to bottom right, #39ac4d, #39fc5d, #d4af37); -fx-background-radius: 20; -fx-padding: 0; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.55), 28, 0.3, 0, 12);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="TOP_LEFT" prefHeight="246.0" prefWidth="416.0" spacing="14" style="-fx-background-color: linear-gradient(to bottom right, #30302e, #101010); -fx-background-radius: 18;">
        <StackPane.margin>
            <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
        </StackPane.margin>
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="popupIconLabel" style="-fx-background-color: #303747; -fx-text-fill: #ffffff; -fx-font-size: 22; -fx-font-weight: 800; -fx-alignment: center; -fx-min-width: 40; -fx-min-height: 40; -fx-max-width: 40; -fx-max-height: 40; -fx-background-radius: 999;" text="!" />
            <VBox spacing="4">
                <Label fx:id="popupTitleLabel" style="-fx-text-fill: #f7f9ff; -fx-font-size: 20; -fx-font-weight: 800;" text="Done" />
                <Label style="-fx-text-fill: #9aa8c7; -fx-font-size: 12;" text="To-•let" />
            </VBox>
        </HBox>

        <Label fx:id="popupMessageLabel" style="-fx-text-fill: #d4def3; -fx-font-size: 14; -fx-line-spacing: 2;" text="Status message" wrapText="true" />

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT">
            <Button fx:id="popupOkButton" style="-fx-background-color: linear-gradient(to right, #39ac4d, #39fc5d); -fx-text-fill: #111827; -fx-font-size: 13; -fx-font-weight: 800; -fx-background-radius: 10; -fx-padding: 10 24 10 24; -fx-cursor: hand;" text="OK" />
        </HBox>
    </VBox>
</StackPane>
