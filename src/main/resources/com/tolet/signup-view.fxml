<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" fillWidth="true" maxHeight="800.0" minHeight="800.0" prefHeight="800.0" prefWidth="400.0" spacing="12" style="-fx-background-color: #99a3b9;" stylesheets="@light-theme.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.SignupPageController">

    <padding>
        <Insets bottom="8" left="14" right="14" top="8" />
    </padding>

    <HBox alignment="TOP_RIGHT" maxWidth="Infinity">
        <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" styleClass="theme-switch">
            <graphic>
                <Region styleClass="switch-knob" />
            </graphic>
        </ToggleButton>
    </HBox>

    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
    <VBox fillWidth="true" maxHeight="700.0" maxWidth="560" minHeight="700.0" prefHeight="700.0" spacing="10" style="-fx-padding: 10 6 10 6;">
        <Label style="-fx-text-fill: #0f172a; -fx-font-size: 28; -fx-font-weight: 800;" text="Create Account" />

        <Label alignment="BOTTOM_LEFT" prefHeight="30.0" style="-fx-text-fill: #0f172a; -fx-font-size: 18;" text="Email / Phone Number" />
        <TextField fx:id="emailField" prefHeight="40.0" promptText="" style="-fx-background-color: #1e2731; -fx-text-fill: #d4af37; -fx-prompt-text-fill: #d4af37; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />

        <Label prefHeight="30.0" style="-fx-text-fill: #0f172a; -fx-font-size: 18;" text="Username" />
        <TextField fx:id="usernameField" prefHeight="40.0" promptText="" style="-fx-background-color: #1e2731; -fx-text-fill: #d4af37; -fx-prompt-text-fill: #d4af37; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />

        <Label prefHeight="30.0" style="-fx-text-fill: #0f172a; -fx-font-size: 18;" text="Password" />
        <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="" style="-fx-background-color: #1e2731; -fx-text-fill: #d4af37; -fx-prompt-text-fill: #d4af37; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />

        <Label prefHeight="30.0" style="-fx-text-fill: #0f172a; -fx-font-size: 18;" text="Account Type" />
        <HBox prefHeight="30.0" spacing="10">
            <ToggleButton fx:id="tenantRoleButton" maxWidth="Infinity" style="-fx-background-color: #1e2731; -fx-text-fill: #d4af37; -fx-font-size: 14; -fx-background-radius: 8; -fx-padding: 8 10 8 10;" styleClass="role-selector-btn" text="Tenant" HBox.hgrow="ALWAYS" />
            <ToggleButton fx:id="ownerRoleButton" maxWidth="Infinity" style="-fx-background-color: #1e2731; -fx-text-fill: #d4af37; -fx-font-size: 14; -fx-background-radius: 8; -fx-padding: 8 10 8 10;" styleClass="role-selector-btn" text="Owner" HBox.hgrow="ALWAYS" />
        </HBox>

        <Label alignment="BOTTOM_LEFT" prefHeight="30.0" style="-fx-text-fill: #0f172a; -fx-font-size: 20;" text="Date of birth" />
        <HBox prefHeight="30.0" spacing="10">
            <ComboBox fx:id="monthCombo" maxWidth="Infinity" style="-fx-background-color: #1e2731; -fx-mark-color: #d4af37; -fx-text-fill: #d4af37; -fx-background-radius: 8; -fx-padding: 8 10 8 10;" styleClass="dob-combo" HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="dayCombo" maxWidth="Infinity" style="-fx-background-color: #1e2731; -fx-mark-color: #d4af37; -fx-text-fill: #d4af37; -fx-background-radius: 8; -fx-padding: 8 10 8 10;" styleClass="dob-combo" HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="yearCombo" maxWidth="Infinity" style="-fx-background-color: #1e2731; -fx-mark-color: #d4af37; -fx-text-fill: #d4af37; -fx-background-radius: 8; -fx-padding: 8 10 8 10;" styleClass="dob-combo" HBox.hgrow="ALWAYS" />
        </HBox>

        <Label fx:id="statusLabel" style="-fx-text-fill: #b91c1c; -fx-font-size: 12;" />

        <Button maxWidth="Infinity" onAction="#onCreateAccount" prefHeight="40.0" prefWidth="345.0" style="-fx-background-color: #f91852; -fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: 800; -fx-background-radius: 4; -fx-padding: 10 0 10 0;" text="Create Account" />

        <Button maxWidth="Infinity" onAction="#onBackToSignIn" prefHeight="40.0" style="-fx-background-color: #cbd5e1; -fx-text-fill: #0f172a; -fx-font-size: 20; -fx-font-weight: 800; -fx-background-radius: 4; -fx-padding: 10 0 10 0;" text="Have an account? Sign in" />
    </VBox>
    </ScrollPane>
</VBox>
