<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="600" prefWidth="900" style="-fx-background-color: #262627;" styleClass="owner-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.OwnerController">
    <stylesheets>
        <URL value="@style.css" />
        <URL value="@dark-style.css" />
        <URL value="@dark-theme.css" />
    </stylesheets>

    <left>
        <VBox maxWidth="250.0" prefHeight="600.0" prefWidth="163.0" spacing="18" style="-fx-background-color: #474743;" styleClass="sidebar">
            <VBox spacing="4" styleClass="brand-block">
                <Label prefHeight="23.0" prefWidth="158.0" style="-fx-text-fill: #ff7547;" styleClass="brand-title" text="To-•Let" />
                <Label prefHeight="14.0" prefWidth="183.0" style="-fx-text-fill: #faa387;" styleClass="brand-subtitle" text="Owner Dashboard" />
            </VBox>

            <VBox spacing="6">
                <Button onAction="#onOpenDashboard" prefHeight="35.0" prefWidth="189.0" style="-fx-background-color: #262624; -fx-text-fill: #ff7547;" styleClass="nav-button" text="Dashboard" />
                <Button onAction="#onOpenAcceptedTenants" prefHeight="35.0" prefWidth="189.0" style="-fx-background-color: #262624; -fx-text-fill: #ff7547;" styleClass="nav-button" text="Tenants" />
                <Button onAction="#onOpenProperties" prefHeight="35.0" prefWidth="212.0" style="-fx-background-color: #30302e; -fx-text-fill: #ff7547; -fx-border-color: #ff7547;" styleClass="nav-button" text="Properties" />
                <Button onAction="#onOpenRequests" prefHeight="35.0" prefWidth="207.0" style="-fx-background-color: #262624; -fx-text-fill: #ff7547;" styleClass="nav-button" text="Requests" />
                <Button onAction="#onOpenAnalytics" prefHeight="35.0" prefWidth="320.0" style="-fx-background-color: #262624; -fx-text-fill: #ff7547;" styleClass="nav-button" text="Analytics" />
                <Button onAction="#onOpenListHouse" prefHeight="42.0" prefWidth="320.0" styleClass="list-house-cta" text="+ List New House" />
            </VBox>

            <Region style="-fx-background-color: #474743;" VBox.vgrow="ALWAYS" />

            <VBox maxWidth="215.0" prefHeight="300.0" prefWidth="215.0" spacing="6" style="-fx-background-color: #262624;" styleClass="profile-card">
                <StackPane alignment="CENTER">
                    <Circle fill="#3a3a37" radius="79.0" stroke="#ff7547" strokeWidth="1.5" />
                    <ImageView fx:id="profileAvatarImage" fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="false" />
                </StackPane>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="profileNameLabel" prefHeight="27.0" prefWidth="198.0" style="-fx-text-fill: #ff7547;" styleClass="profile-name" text="Owner" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#onOpenProfile" style="-fx-background-color: #262624; -fx-text-fill: #ff7547; -fx-border-color: #ff7547; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 2 8;" text="&#9998;" />
                </HBox>                <Label fx:id="profileVerificationLabel" prefHeight="20.0" prefWidth="214.0" style="-fx-text-fill: #faa387;" styleClass="profile-role" text="Status - Unverified" />
                <Label fx:id="profileRoleLabel" prefHeight="20.0" prefWidth="214.0" style="-fx-text-fill: #faa387;" styleClass="profile-role" text="Role - Owner" />
                <Label fx:id="profileEmailLabel" prefHeight="20.0" prefWidth="205.0" style="-fx-text-fill: #faa387;" styleClass="profile-role" text="Email: -" />
                <Label fx:id="profilePhoneLabel" prefHeight="20.0" prefWidth="232.0" style="-fx-text-fill: #faa387;" styleClass="profile-role" text="Phone: -" />
                <Button onAction="#onLogout" prefHeight="34.0" prefWidth="264.0" style="-fx-background-color: #474743; -fx-text-fill: #e8fff5; -fx-border-color: #e8fff5;" styleClass="ghost-button" text="Logout" />
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #262624;" styleClass="content-scroll">
            <VBox fx:id="propertiesPageRoot" maxHeight="2000.0" prefHeight="1080.0" prefWidth="691.0" spacing="22" style="-fx-background-color: #262624;" styleClass="content-root">
                <HBox alignment="TOP_RIGHT">
                    <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" style="-fx-background-color: #99a3b4;" styleClass="theme-switch">
                        <graphic>
                            <Region style="-fx-background-color: #5700d2;" styleClass="switch-knob" />
                        </graphic>
                    </ToggleButton>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #30302e;" styleClass="top-bar">
                    <VBox spacing="4">
                        <Label style="-fx-background-color: #30302e; -fx-text-fill: #ff7547;" styleClass="page-title" text="Properties" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="dateLabel" style="-fx-background-color: #474743; -fx-text-fill: #e8fff5;" styleClass="date-pill" text="" />
                </HBox>

                <VBox spacing="12" style="-fx-background-color: #30302e;" styleClass="panel">
                    <Label style="-fx-text-fill: #ff7547;" styleClass="panel-title" text="Your Properties" />
                    <VBox fx:id="propertiesCardsContainer" spacing="10" />
                </VBox>

                <VBox spacing="12" style="-fx-background-color: #30302e;" styleClass="panel">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label style="-fx-text-fill: #ff7547;" styleClass="panel-title" text="Property Details" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onOpenHouseProfile" styleClass="ghost-button" text="Edit" />
                    </HBox>
                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label fx:id="propertyTitleLabel" style="-fx-text-fill: #e8fff5;" text="Title: -" />
                            <Label fx:id="propertyLocationLabel" style="-fx-text-fill: #e8fff5;" text="Location: -" />
                            <Label fx:id="propertyTypeLabel" style="-fx-text-fill: #e8fff5;" text="Type: -" />
                            <Label fx:id="propertyPriceLabel" style="-fx-text-fill: #e8fff5;" text="Rent: -" />
                            <Label fx:id="propertySizeLabel" style="-fx-text-fill: #e8fff5;" text="Size: -" />
                            <Label fx:id="propertyAvailabilityLabel" style="-fx-text-fill: #e8fff5;" text="Availability: -" />
                            <Label fx:id="propertyContactLabel" style="-fx-text-fill: #e8fff5;" text="Contact: -" />
                            <Label fx:id="propertyDetailsLabel" style="-fx-text-fill: #e8fff5;" text="Details: -" wrapText="true" />
                        </VBox>
                        <HBox spacing="10" styleClass="property-detail-images" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="property-detail-image-slot">
                                <ImageView fx:id="propertyImage1" fitHeight="130.0" fitWidth="170.0" pickOnBounds="true" preserveRatio="true" styleClass="property-detail-image" />
                            </StackPane>
                            <StackPane styleClass="property-detail-image-slot">
                                <ImageView fx:id="propertyImage2" fitHeight="130.0" fitWidth="170.0" pickOnBounds="true" preserveRatio="true" styleClass="property-detail-image" />
                            </StackPane>
                            <StackPane styleClass="property-detail-image-slot">
                                <ImageView fx:id="propertyImage3" fitHeight="130.0" fitWidth="170.0" pickOnBounds="true" preserveRatio="true" styleClass="property-detail-image" />
                            </StackPane>
                        </HBox>
                    </HBox>

                    <Label prefHeight="18.0" prefWidth="594.0" style="-fx-text-fill: #ff7547;" styleClass="panel-title" text="Tenant Requests For This House" />
                    <VBox spacing="8" styleClass="table">
                        <HBox spacing="16" style="-fx-background-color: #30302e;" styleClass="table-header">
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Tenant" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Request Date" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Move-in Date" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Status" />
                        </HBox>
                        <VBox fx:id="propertyRequestsContainer" spacing="8" />
                    </VBox>

                    <Label prefHeight="18.0" prefWidth="594.0" style="-fx-text-fill: #ff7547;" styleClass="panel-title" text="Tenant Reviews For This House" />
                    <VBox spacing="8" styleClass="table">
                        <HBox spacing="16" style="-fx-background-color: #30302e;" styleClass="table-header">
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Tenant" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Date" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Review" />
                        </HBox>
                        <VBox fx:id="propertyReviewsContainer" spacing="8" />
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>





