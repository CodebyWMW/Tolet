<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="900.0" spacing="12"
      style="-fx-background-color: #0f111a;"
      stylesheets="@dark-theme.css"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tolet.ForgotPasswordController">

    <padding>
        <Insets top="24" right="28" bottom="24" left="28"/>
    </padding>

    <HBox alignment="TOP_RIGHT" maxWidth="Infinity">
        <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" styleClass="theme-switch">
            <graphic>
                <Region styleClass="switch-knob" />
            </graphic>
        </ToggleButton>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
        <VBox maxWidth="520" spacing="16" style="-fx-padding: 10 6 10 6;" prefWidth="520">
            <Label fx:id="stepLabel" text="Reset Your Password" style="-fx-text-fill: #f3f5fb; -fx-font-size: 36; -fx-font-weight: 800;" />

            <!-- Step 1: Email Input -->
            <VBox spacing="8" fx:id="emailStep">
                <Label text="Enter your registered email" style="-fx-text-fill: #f3f5fb; -fx-font-size: 16;" />
                <TextField fx:id="emailField" promptText="your@email.com"
                           style="-fx-background-color: #222635; -fx-text-fill: #f3f5fb; -fx-prompt-text-fill: #9ea3b0; -fx-background-radius: 8; -fx-padding: 12 14 12 14;"
                           prefHeight="50" />
                <Button text="Send OTP" onAction="#onSendOTP" maxWidth="Infinity"
                        style="-fx-background-color: #f91852; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 10 0 10 0;" />
            </VBox>

            <!-- Step 2: OTP Verification -->
            <VBox spacing="8">
                <Label text="Enter the OTP code sent to your email" style="-fx-text-fill: #f3f5fb; -fx-font-size: 16;" />
                <TextField fx:id="otpField" promptText="123456"
                           style="-fx-background-color: #222635; -fx-text-fill: #f3f5fb; -fx-prompt-text-fill: #9ea3b0; -fx-background-radius: 8; -fx-padding: 12 14 12 14;"
                           prefHeight="50" visible="false" managed="false" />
                <Button text="Verify OTP" onAction="#onVerifyOTP" maxWidth="Infinity" visible="false" managed="false"
                        style="-fx-background-color: #f91852; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 10 0 10 0;" />
            </VBox>

            <!-- Step 3: New Password -->
            <VBox spacing="8">
                <Label text="New Password" style="-fx-text-fill: #f3f5fb; -fx-font-size: 16;" />
                <PasswordField fx:id="newPasswordField" promptText="Enter new password"
                               style="-fx-background-color: #222635; -fx-text-fill: #f3f5fb; -fx-prompt-text-fill: #9ea3b0; -fx-background-radius: 8; -fx-padding: 12 14 12 14;"
                               prefHeight="50" visible="false" managed="false" />
                <Label text="Confirm Password" style="-fx-text-fill: #f3f5fb; -fx-font-size: 16;" visible="false" managed="false" />
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password"
                               style="-fx-background-color: #222635; -fx-text-fill: #f3f5fb; -fx-prompt-text-fill: #9ea3b0; -fx-background-radius: 8; -fx-padding: 12 14 12 14;"
                               prefHeight="50" visible="false" managed="false" />
                <Button text="Reset Password" onAction="#onResetPassword" maxWidth="Infinity" visible="false" managed="false"
                        style="-fx-background-color: #f91852; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 10 0 10 0;" />
            </VBox>

            <Label fx:id="statusLabel" style="-fx-text-fill: #ff8a8a; -fx-font-size: 14;" wrapText="true" />

            <Button text="Back to Sign In" onAction="#onBackToLogin" maxWidth="Infinity"
                    style="-fx-background-color: #36384a; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 10 0 10 0;" />
        </VBox>
    </ScrollPane>
</VBox>
