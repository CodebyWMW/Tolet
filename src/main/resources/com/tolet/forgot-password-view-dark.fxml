<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefHeight="900.0" prefWidth="400.0" spacing="12" style="-fx-background-color: #30302e;" stylesheets="@dark-theme.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.ForgotPasswordController">

    <padding>
        <Insets bottom="24" left="28" right="28" top="24" />
    </padding>

    <HBox alignment="TOP_RIGHT" maxWidth="Infinity">
        <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" styleClass="theme-switch">
            <graphic>
                <Region styleClass="switch-knob" />
            </graphic>
        </ToggleButton>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
        <content>
        <VBox maxWidth="520" prefWidth="520" spacing="22" style="-fx-padding: 14 6 14 6;">
            <Label fx:id="stepLabel" style="-fx-text-fill: #ff7547; -fx-font-size: 24; -fx-font-weight: 800;" text="Reset Your Password" />

            <!-- Step 1: Email / Phone Input -->
            <VBox fx:id="emailStep" spacing="12">
                <Label maxWidth="Infinity" style="-fx-text-fill: #f3f5fb; -fx-font-size: 14;" text="Enter your registered email or phone number" wrapText="true" />
                <TextField fx:id="emailField" prefHeight="50" promptText="murgi@email.com or 016767XXXXX" style="-fx-background-color: #39ac4d; -fx-text-fill: #000000; -fx-prompt-text-fill: #000000; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />
                <Button fx:id="sendOtpButton" maxWidth="Infinity" onAction="#onSendOTP" style="-fx-background-color: #f91852; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 0 10 0;" text="Send OTP" />
            </VBox>

            <!-- Step 2: OTP Verification -->
            <VBox fx:id="otpStep" spacing="12">
                <Label maxWidth="Infinity" style="-fx-text-fill: #f3f5fb; -fx-font-size: 16;" text="Enter the OTP code sent to your email or phone" wrapText="true" />
                <TextField fx:id="otpField" prefHeight="50" promptText="1234" style="-fx-background-color: #39ac4d; -fx-text-fill: #000000; -fx-prompt-text-fill: #000000; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />
                <Button maxWidth="Infinity" onAction="#onVerifyOTP" style="-fx-background-color: #f91852; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 0 10 0;" text="Verify OTP" />
            </VBox>

            <!-- Step 3: New Password -->
            <VBox fx:id="passwordStep" spacing="12">
                <Label style="-fx-text-fill: #f3f5fb; -fx-font-size: 16;" text="New Password" />
                <PasswordField fx:id="newPasswordField" prefHeight="50" promptText="Enter new password" style="-fx-background-color: #39ac4d; -fx-text-fill: #000000; -fx-prompt-text-fill: #000000; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />
                <Label style="-fx-text-fill: #f3f5fb; -fx-font-size: 16;" text="Confirm Password" />
                <PasswordField fx:id="confirmPasswordField" prefHeight="50" promptText="Confirm new password" style="-fx-background-color: #39ac4d; -fx-text-fill: #000000; -fx-prompt-text-fill: #000000; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />
                <Button maxWidth="Infinity" onAction="#onResetPassword" style="-fx-background-color: #f91852; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 0 10 0;" text="Reset Password" />
            </VBox>

                <Label fx:id="statusLabel" style="-fx-text-fill: #f3f5fb; -fx-font-size: 14;" wrapText="true" />

            <Button maxWidth="Infinity" onAction="#onBackToLogin" style="-fx-background-color: #525252; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 0 10 0;" text="Back to Sign In" />
        </VBox>
            </content>
    </ScrollPane>
</VBox>
