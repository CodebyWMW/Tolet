<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" fillWidth="true" prefHeight="900.0" prefWidth="400.0" spacing="12" style="-fx-background-color: #30302e; -fx-font-family: 'Press Start 2P';" stylesheets="@dark-theme.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tolet.SignupPageController">

    <padding>
        <Insets bottom="8" left="14" right="14" top="8" />
    </padding>

    <HBox alignment="TOP_RIGHT" maxWidth="Infinity">
        <ToggleButton fx:id="themeToggle" onAction="#onThemeToggle" styleClass="theme-switch">
            <graphic>
                <Region styleClass="switch-knob" />
            </graphic>
        </ToggleButton>
    </HBox>

    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-control-inner-background: transparent;" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
    <VBox fillWidth="true" maxWidth="560" spacing="10" style="-fx-padding: 10 6 10 6; -fx-background-color: transparent;">
          <Label style="-fx-text-fill: #f3f5fb; -fx-font-size: 13; -fx-font-weight: 800;" text="Create Account" />

        <Label alignment="BOTTOM_LEFT" prefHeight="40.0" style="-fx-text-fill: #f3f5fb; -fx-font-size: 10;" text="Email/ Phone Number" />
        <TextField fx:id="emailField" prefHeight="50" promptText="" style="-fx-background-color: #39ac4d; -fx-text-fill: #000000; -fx-prompt-text-fill: #9ea #0000003b0; -fx-background-radius: 8; -fx-padding: 12 14 12 14; -fx-prompt-fill: #39ac4d;" />

        <Label style="-fx-text-fill: #f3f5fb; -fx-font-size: 11;" text="Username" />
        <TextField fx:id="usernameField" prefHeight="50" promptText="" style="-fx-background-color: #39ac4d; -fx-text-fill: #000000; -fx-prompt-text-fill: #9ea #0000003b0; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />

        <Label style="-fx-text-fill: #f3f5fb; -fx-font-size: 11;" text="Password" />
        <PasswordField fx:id="passwordField" prefHeight="50" promptText="" style="-fx-background-color: #39ac4d; -fx-text-fill: #000000; -fx-prompt-text-fill: #9ea #0000003b0; -fx-background-radius: 8; -fx-padding: 12 14 12 14;" />

        <Label style="-fx-text-fill: #f3f5fb; -fx-font-size: 11;" text="Account Type" />
        <HBox spacing="10">
            <ToggleButton fx:id="tenantRoleButton" maxWidth="Infinity" prefHeight="35.0" style="-fx-background-radius: 25; -fx-background-color: #39ac4d; -fx-font-size: 11;" styleClass="role-selector-btn" text="Tenant" HBox.hgrow="ALWAYS">
               <font>
                  <Font size="14.0" />
               </font></ToggleButton>
            <ToggleButton fx:id="ownerRoleButton" maxWidth="Infinity" prefHeight="35.0" style="-fx-background-radius: 25; -fx-background-color: #39ac4d; -fx-font-size: 11;" styleClass="role-selector-btn" text="Owner" HBox.hgrow="ALWAYS" />
        </HBox>

        <Label alignment="BOTTOM_LEFT" prefHeight="30.0" style="-fx-text-fill: #f3f5fb; -fx-font-size: 11;" text="Date of birth" />
        <HBox prefHeight="30.0" spacing="5.0">
            <ComboBox fx:id="monthCombo" maxWidth="Infinity" style="-fx-background-color: #39ac4d; -fx-mark-color: #000000; -fx-text-fill: #000000; -fx-background-radius: 8; -fx-padding: 8 10 8 10;" styleClass="dob-combo" HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="dayCombo" maxWidth="Infinity" style="-fx-background-color: #39ac4d; -fx-mark-color: #000000; -fx-text-fill: #000000; -fx-background-radius: 8; -fx-padding: 8 10 8 10;" styleClass="dob-combo" HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="yearCombo" maxWidth="Infinity" style="-fx-background-color: #39ac4d; -fx-mark-color: #000000; -fx-text-fill: #000000; -fx-background-radius: 8; -fx-padding: 8 10 8 10;" styleClass="dob-combo" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="-10.0" />
               </padding></ComboBox>
        </HBox>

        <Label fx:id="statusLabel" style="-fx-font-size: 10;" />

        <Button maxWidth="Infinity" onAction="#onCreateAccount" prefHeight="40.0" style="-fx-background-color: #f91852; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: 800; -fx-background-radius: 10; -fx-padding: 10 0 10 0;" text="Create Account">
            <VBox.margin>
               <Insets top="5.0" />
            </VBox.margin></Button>

        <Button maxWidth="Infinity" onAction="#onBackToSignIn" prefHeight="40.0" style="-fx-background-color: #525252; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: 800; -fx-background-radius: 10; -fx-padding: 10 0 10 0;" text="Have an account? Sign in">
            <padding>
               <Insets top="10.0" />
            </padding></Button>
    </VBox>
    </ScrollPane>
</VBox>
