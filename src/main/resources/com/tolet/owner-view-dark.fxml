                        <Region styleClass="chart-bar" prefHeight="124"/>
                        <Region styleClass="chart-bar" prefHeight="130"/>
                        <Region styleClass="chart-bar" prefHeight="112"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="chart-labels">
                        <Label text="Jan" styleClass="chart-label"/>
                        <Label text="Feb" styleClass="chart-label"/>
                        <Label text="Mar" styleClass="chart-label"/>
                        <Label text="Apr" styleClass="chart-label"/>
                        <Label text="May" styleClass="chart-label"/>
                        <Label text="Jun" styleClass="chart-label"/>
                        <Label text="Jul" styleClass="chart-label"/>
                        <Label text="Aug" styleClass="chart-label"/>
                        <Label text="Sep" styleClass="chart-label"/>
                        <Label text="Oct" styleClass="chart-label"/>
                        <Label text="Nov" styleClass="chart-label"/>
                        <Label text="Dec" styleClass="chart-label"/>
                    </HBox>
                </VBox>
                -->

                <VBox maxHeight="1000.0" prefHeight="187.0" prefWidth="643.0" spacing="12" style="-fx-background-color: #30302e;" styleClass="panel">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label style="-fx-text-fill: #ff7547;" styleClass="panel-title" text="Tenant Booking Requests" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onOpenRequests" prefHeight="30.0" prefWidth="88.0" styleClass="ghost-button" text="See All" />
                    </HBox>
                    <VBox spacing="8" styleClass="table">
                        <HBox spacing="16" style="-fx-background-color: #30302e;" styleClass="table-header">
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Tenant Name" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Property" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Request Date" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Move-in Date" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Monthly Rent" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Status" />
                            <Label prefWidth="192.0" style="-fx-text-fill: #faa387;" styleClass="table-title" text="Actions" />
                        </HBox>

                        <VBox fx:id="requestsContainer" spacing="8" />
                    </VBox>
                </VBox>

                <VBox maxHeight="1000.0" prefHeight="187.0" prefWidth="643.0" spacing="12" style="-fx-background-color: #30302e;" styleClass="panel">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label style="-fx-text-fill: #ff7547;" styleClass="panel-title" text="Your Listed Houses" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onOpenProperties" prefHeight="30.0" prefWidth="88.0" styleClass="ghost-button" text="See All" />
                    </HBox>
                    <VBox spacing="8" styleClass="table">
                        <HBox spacing="16" style="-fx-background-color: #30302e;" styleClass="table-header">
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Title" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Location" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Asking Price" />
                            <Label style="-fx-text-fill: #faa387;" styleClass="table-title" text="Status" />
                        </HBox>

                        <VBox fx:id="listedHousesContainer" spacing="8" />
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
